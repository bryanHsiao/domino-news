---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import { getPostsByLang, getAllTags } from '../../lib/posts';
import { useTranslations } from '../../i18n/ui';

export async function getStaticPaths() {
  const tags = await getAllTags('zh-TW');
  const posts = await getPostsByLang('zh-TW');
  return tags.map(({ tag }) => ({
    params: { tag },
    props: { tag, posts: posts.filter((p) => p.data.tags.includes(tag)) },
  }));
}

const lang = 'zh-TW' as const;
const t = useTranslations(lang);
const { tag, posts } = Astro.props;
---

<BaseLayout lang={lang} title={`#${tag}`}>
  <h1>#{tag}</h1>
  <p>{t('tags.postsTagged')} <strong>#{tag}</strong> · {posts.length} {t('tags.posts')}</p>
  <PostList
    lang={lang}
    posts={posts.map((p) => ({
      slug: p.data.slug,
      title: p.data.title,
      description: p.data.description,
      pubDate: p.data.pubDate,
      tags: p.data.tags,
    }))}
  />
</BaseLayout>
