---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/ui';

const lang = 'zh-TW' as const;
const t = useTranslations(lang);
const base = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');
const pagefindCss = `${base}/pagefind/pagefind-ui.css`;
const pagefindJs = `${base}/pagefind/pagefind-ui.js`;
const pagefindBundle = `${base}/pagefind/`;
---

<BaseLayout lang={lang} title={t('search.title')} description={t('search.hint')}>
  <section class="search-page">
    <h1>{t('search.heading')}</h1>
    <p class="search-hint">{t('search.hint')}</p>
    <link rel="stylesheet" href={pagefindCss} />
    <div id="search"></div>
    <script is:inline define:vars={{ pagefindJs, pagefindBundle }}>
      // Init runs at script-execution time (not DOMContentLoaded) so it
      // works under view transitions too — the inline script re-runs on
      // each navigation to /search, and at that moment the #search div
      // above is already in the DOM.
      //
      // Dataset-based idempotency guard prevents double-init if the
      // event fires twice (initial load + astro:page-load).
      //
      // If user revisits /search after first load, window.PagefindUI is
      // already in scope (the script we appended to <head> persists across
      // view transitions) — just re-instantiate the UI on the fresh
      // #search element instead of re-downloading.
      (function () {
        var el = document.getElementById('search');
        if (!el || el.dataset.pfInited) return;
        el.dataset.pfInited = 'true';

        var uiOpts = {
          element: '#search',
          bundlePath: pagefindBundle,
          showSubResults: true,
          showImages: true,
          translations: {
            placeholder: '搜尋文章…',
            zero_results: '沒有找到符合「[SEARCH_TERM]」的結果',
            load_more: '載入更多結果',
            search_label: '在 Domino News 中搜尋',
            filters_label: '篩選',
            clear_search: '清除',
          },
        };

        if (typeof window.PagefindUI !== 'undefined') {
          new window.PagefindUI(uiOpts);
          return;
        }

        var script = document.createElement('script');
        script.src = pagefindJs;
        script.onerror = function () {
          el.innerHTML =
            '<p style="color:#999;font-size:0.95rem;padding:1rem 0">⚠️ 搜尋索引尚未生成 — 本地預覽請跑 <code>npm run build</code> + <code>npm run preview</code>。Production 站正常。</p>';
        };
        script.onload = function () {
          new window.PagefindUI(uiOpts);
        };
        document.head.appendChild(script);
      })();
    </script>
  </section>
</BaseLayout>

<style>
  .search-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .search-page h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  .search-hint {
    color: var(--text-muted, #666);
    margin-bottom: 2rem;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  /* Theme Pagefind UI to match site brand (black + gold) */
  :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--color-brand-dark, #0a0a0a);
    --pagefind-ui-text: var(--text, #333);
    --pagefind-ui-background: white;
    --pagefind-ui-border: var(--border-color, #e5e5e5);
    --pagefind-ui-border-radius: 0.6rem;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-font: inherit;
  }
</style>
