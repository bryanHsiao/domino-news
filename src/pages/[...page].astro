---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostList from '../components/PostList.astro';
import Pagination from '../components/Pagination.astro';
import { getPostsByLang } from '../lib/posts';
import { useTranslations } from '../i18n/ui';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPostsByLang('zh-TW');
  return paginate(
    posts.map((p) => ({
      slug: p.data.slug,
      title: p.data.title,
      description: p.data.description,
      pubDate: p.data.pubDate,
      tags: p.data.tags,
      cover: p.data.cover,
    })),
    { pageSize: 9 }
  );
}) satisfies GetStaticPaths;

const lang = 'zh-TW' as const;
const t = useTranslations(lang);
const { page } = Astro.props;
const isFirstPage = page.currentPage === 1;
const base = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');
---

<BaseLayout lang={lang}>
  {
    isFirstPage && (
      <>
        <div class="hero" aria-hidden="true">
          <img src={`${base}/covers/welcome.png`} alt="" loading="eager" />
        </div>
        <h1>{t('site.tagline')}</h1>
        <p class="lead">{t('site.description')}</p>
        <h2>{t('home.latest')}</h2>
      </>
    )
  }

  <PostList lang={lang} posts={page.data} />

  <Pagination
    lang={lang}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    basePath=""
  />
</BaseLayout>
