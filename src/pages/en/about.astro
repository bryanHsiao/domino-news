---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t('about.title')}>
  <h1>{t('about.title')}</h1>
  <p>
    This site focuses on <strong>HCL Domino</strong> and its broader ecosystem
    (Notes, Domino REST API, Volt MX, Nomad, AppDev Pack, and more) — covering
    the latest news and technical articles.
  </p>
  <p>
    Topics come from the last 24–72 hours of official HCL announcements,
    HCL Ambassador blogs, and OpenNTF activity — on days without news, the post
    is a deep-dive on an under-covered class or feature from the official docs.
    Every post lists its sources at the bottom.
  </p>
  <p>
    Traditional Chinese and English versions are published together. The full
    publishing workflow is
    <a href="https://github.com/bryanHsiao/domino-news">open-sourced on GitHub</a>.
  </p>
</BaseLayout>
