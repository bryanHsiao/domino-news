---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostList from '../../components/PostList.astro';
import Pagination from '../../components/Pagination.astro';
import { getPostsByLang } from '../../lib/posts';
import { useTranslations } from '../../i18n/ui';

export const getStaticPaths = (async ({ paginate }) => {
  const posts = await getPostsByLang('en');
  return paginate(
    posts.map((p) => ({
      slug: p.data.slug,
      title: p.data.title,
      description: p.data.description,
      pubDate: p.data.pubDate,
      tags: p.data.tags,
      cover: p.data.cover,
    })),
    { pageSize: 9 }
  );
}) satisfies GetStaticPaths;

const lang = 'en' as const;
const t = useTranslations(lang);
const { page } = Astro.props;
const isFirstPage = page.currentPage === 1;
const base = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');
const siteOrigin = Astro.site?.origin ?? 'https://bryanhsiao.github.io';
const siteRoot = `${siteOrigin}${base}/`;
const enRoot = `${siteOrigin}${base}/en/`;

// Home-only JSON-LD: WebSite with SearchAction so Google can show a
// sitelinks search box for the site. URL template uses /en/search/?q=…;
// search.astro reads the q parameter and pre-fills the Pagefind input.
const homeJsonLd = isFirstPage
  ? {
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: 'HCL Domino Daily',
      alternateName: 'HCL Domino Daily (English)',
      url: enRoot,
      description: t('site.description'),
      inLanguage: 'en',
      potentialAction: {
        '@type': 'SearchAction',
        target: {
          '@type': 'EntryPoint',
          urlTemplate: `${enRoot}search/?q={search_term_string}`,
        },
        'query-input': 'required name=search_term_string',
      },
      publisher: {
        '@type': 'Organization',
        name: 'HCL Domino Daily',
        url: siteRoot,
        logo: {
          '@type': 'ImageObject',
          url: `${siteRoot}logo.png`,
        },
      },
    }
  : undefined;
---

<BaseLayout lang={lang} jsonLd={homeJsonLd}>
  {
    isFirstPage && (
      <>
        <div class="hero" aria-hidden="true">
          <img src={`${base}/covers/welcome.webp`} alt="" loading="eager" />
        </div>
        <h1>{t('site.tagline')}</h1>
        <p class="lead">{t('site.description')}</p>
        <h2>{t('home.latest')}</h2>
      </>
    )
  }

  <PostList lang={lang} posts={page.data} />

  <Pagination
    lang={lang}
    currentPage={page.currentPage}
    lastPage={page.lastPage}
    prevUrl={page.url.prev}
    nextUrl={page.url.next}
    basePath="/en"
  />
</BaseLayout>
