---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/ui';

const lang = 'en' as const;
const t = useTranslations(lang);
const base = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');
const pagefindCss = `${base}/pagefind/pagefind-ui.css`;
const pagefindJs = `${base}/pagefind/pagefind-ui.js`;
const pagefindBundle = `${base}/pagefind/`;
---

<BaseLayout lang={lang} title={t('search.title')} description={t('search.hint')}>
  <section class="search-page">
    <h1>{t('search.heading')}</h1>
    <p class="search-hint">{t('search.hint')}</p>
    <link rel="stylesheet" href={pagefindCss} />
    <div id="search"></div>
    <script is:inline define:vars={{ pagefindJs, pagefindBundle }}>
      // See the comment in /search.astro for the rationale — same
      // astro:page-load pattern, just with English UI defaults instead of
      // zh-TW translations.
      (function () {
        var uiOpts = {
          element: '#search',
          bundlePath: pagefindBundle,
          showSubResults: true,
          showImages: true,
        };

        // Read ?q= from URL and pre-fill the Pagefind input. Supports
        // the WebSite + SearchAction JSON-LD on the homepage (Google
        // sitelinks search box) and any external direct-search links.
        function applyQueryFromUrl() {
          var params = new URLSearchParams(window.location.search);
          var q = params.get('q');
          if (!q) return;
          var tryFill = function (retries) {
            var input = document.querySelector('.pagefind-ui__search-input');
            if (input) {
              input.value = q;
              input.dispatchEvent(new Event('input', { bubbles: true }));
              input.focus();
            } else if (retries > 0) {
              setTimeout(function () { tryFill(retries - 1); }, 50);
            }
          };
          tryFill(20);
        }

        // Put the cursor in the search box as soon as it renders, so the
        // user can type the moment they land on /search. PagefindUI creates
        // the input asynchronously, so retry briefly until it exists.
        function focusSearchInput() {
          var tryFocus = function (retries) {
            var input = document.querySelector('.pagefind-ui__search-input');
            if (input) {
              input.focus();
            } else if (retries > 0) {
              setTimeout(function () { tryFocus(retries - 1); }, 50);
            }
          };
          tryFocus(20);
        }

        // Mount Pagefind into #search, VERIFYING the input actually rendered.
        // Under view transitions the freshly-swapped #search can momentarily
        // not be queryable when PagefindUI runs (it logs "couldn't find the
        // selector" and renders nothing). The search box renders synchronously,
        // so we check right after and retry on a fresh #search until it sticks.
        function tryMount(retries) {
          // Only the en page — the zh page has its own initialiser.
          if ((document.documentElement.lang || '').toLowerCase().indexOf('zh') === 0) return;
          var el = document.getElementById('search');
          if (!el) {
            if (retries > 0) setTimeout(function () { tryMount(retries - 1); }, 50);
            return;
          }
          if (el.querySelector('.pagefind-ui__search-input')) return; // already mounted

          if (typeof window.PagefindUI === 'undefined') {
            if (!window.__pfScriptLoading) {
              window.__pfScriptLoading = true;
              var script = document.createElement('script');
              script.src = pagefindJs;
              script.onerror = function () {
                el.innerHTML =
                  '<p style="color:#999;font-size:0.95rem;padding:1rem 0">⚠️ Search index not generated — for local preview run <code>npm run build</code> + <code>npm run preview</code>. Live site is fine.</p>';
              };
              script.onload = function () { tryMount(20); };
              document.head.appendChild(script);
            } else if (retries > 0) {
              setTimeout(function () { tryMount(retries - 1); }, 50);
            }
            return;
          }

          el.innerHTML = '';
          // Pass the resolved node, not the '#search' selector string:
          // PagefindUI's own selector lookup can miss the freshly-swapped
          // element under view transitions (it then logs "couldn't find the
          // selector" and renders nothing). Handing it the node we already
          // resolved sidesteps that entirely.
          uiOpts.element = el;
          new window.PagefindUI(uiOpts);
          if (el.querySelector('.pagefind-ui__search-input')) {
            applyQueryFromUrl();
            focusSearchInput();
          } else if (retries > 0) {
            setTimeout(function () { tryMount(retries - 1); }, 50);
          }
        }

        // Run on this load, and re-run after every view-transition navigation.
        // Astro dedupes identical is:inline scripts, so this body won't re-run
        // on repeat visits to /search — the persistent astro:page-load listener
        // (bound once) is what re-mounts on each navigation.
        tryMount(20);
        if (!window.__pfSearchBoundEn) {
          window.__pfSearchBoundEn = true;
          document.addEventListener('astro:page-load', function () { tryMount(20); });
        }
      })();
    </script>
  </section>
</BaseLayout>

<style>
  .search-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }
  .search-page h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  .search-hint {
    color: var(--text-muted, #666);
    margin-bottom: 2rem;
    font-size: 0.95rem;
    line-height: 1.6;
  }
  /* Theme Pagefind UI to match site brand (black + gold) */
  :global(.pagefind-ui) {
    --pagefind-ui-primary: var(--color-brand-dark, #0a0a0a);
    --pagefind-ui-text: var(--text, #333);
    --pagefind-ui-background: white;
    --pagefind-ui-border: var(--border-color, #e5e5e5);
    --pagefind-ui-border-radius: 0.6rem;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-font: inherit;
  }
</style>
