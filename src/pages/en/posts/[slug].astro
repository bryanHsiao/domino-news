---
import { render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getPostsByLang, postReadingStats, getRelatedPosts } from '../../../lib/posts';
import { tagPalette, slugGradient } from '../../../lib/tags';
import { useTranslations, localizedPath } from '../../../i18n/ui';

export async function getStaticPaths() {
  const posts = await getPostsByLang('en');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const lang = 'en' as const;
const t = useTranslations(lang);
const { post } = Astro.props;
const { Content } = await render(post);
const base = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');
const dateFormatter = new Intl.DateTimeFormat('en-US', {
  timeZone: 'Asia/Taipei',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const cover = post.data.cover ? `${base}${post.data.cover.startsWith('/') ? post.data.cover : `/${post.data.cover}`}` : null;
const grad = slugGradient(post.data.slug);
const stats = postReadingStats(post.body ?? '', lang);
const wordCountLabel = t('post.wordCount').replace('{n}', stats.words.toLocaleString('en-US'));
const dateLabel = post.data.pubDate.toLocaleDateString('en-US', {
  timeZone: 'Asia/Taipei',
  year: 'numeric', month: 'short', day: 'numeric',
});

const siteOrigin = Astro.site?.origin ?? 'https://bryanhsiao.github.io';
const canonical = new URL(Astro.url.pathname, Astro.site ?? siteOrigin).toString();
const absCover = post.data.cover
  ? `${siteOrigin}${base}${post.data.cover.startsWith('/') ? post.data.cover : `/${post.data.cover}`}`
  : undefined;

// Extract identifier-shaped tokens from the markdown body (backticks-wrapped
// camelCase or @-prefixed names like `NotesDateTime`, `@FTSearch`, `cert.id`).
// These are stronger SEO signals than just the frontmatter tags — readers
// searching for "NotesDateTime" should be able to find a post that doesn't
// have NotesDateTime as a tag but mentions it 30 times in code blocks.
const inlineIdentifiers = Array.from(
  new Set([...(post.body ?? '').matchAll(/`(@?[A-Za-z][\w.-]+)`/g)].map((m) => m[1]))
)
  .filter((s) => /[A-Z@]/.test(s)) // keep PascalCase / @function / mixed-case identifiers
  .slice(0, 12);
const keywordsList = [...post.data.tags, ...inlineIdentifiers];

const related = await getRelatedPosts(post, lang, 4);
// JSON-LD as @graph so we can emit BlogPosting + BreadcrumbList
// in a single <script> tag. BlogPosting carries article metadata
// (author, dates, image, publisher.logo for rich result); BreadcrumbList
// powers SERP breadcrumb display under the title.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'BlogPosting',
      headline: post.data.title,
      description: post.data.description,
      datePublished: post.data.pubDate.toISOString(),
      dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
      author: {
        '@type': 'Person',
        name: 'Bryan Hsiao',
        url: 'https://github.com/bryanHsiao',
      },
      inLanguage: 'en',
      mainEntityOfPage: canonical,
      url: canonical,
      ...(absCover ? { image: absCover.replace(/\.webp$/, '.png') } : {}),
      keywords: keywordsList.join(', '),
      publisher: {
        '@type': 'Organization',
        name: 'Domino News',
        url: siteOrigin + base + '/',
        logo: {
          '@type': 'ImageObject',
          url: `${siteOrigin}${base}/logo.png`,
        },
      },
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: t('breadcrumb.home'), item: `${siteOrigin}${base}/en/` },
        { '@type': 'ListItem', position: 2, name: t('breadcrumb.posts'), item: `${siteOrigin}${base}/en/posts/` },
        { '@type': 'ListItem', position: 3, name: post.data.title, item: canonical },
      ],
    },
  ],
};
---

<BaseLayout
  lang={lang}
  title={post.data.title}
  description={post.data.description}
  cover={post.data.cover}
  ogType="article"
  jsonLd={jsonLd}
>
  <article class="post" data-pagefind-body data-pagefind-meta={`image:${cover ?? ''}`}>
    {post.data.slug !== 'welcome' && (
      cover ? (
        <div class="post-cover">
          <img src={cover} alt={post.data.title} loading="eager" decoding="async" />
        </div>
      ) : (
        <div class="post-cover fallback" style={`--g-from:${grad.from};--g-to:${grad.to}`}>
          {post.data.tags[0] && <span class="cover-icon">{post.data.tags[0]}</span>}
        </div>
      )
    )}

    <div class="post-body">
      <nav class="breadcrumb" aria-label="breadcrumb">
        <a href={localizedPath(lang, '/')}>
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12l9-9 9 9"/><path d="M5 10v10h14V10"/></svg>
          {t('breadcrumb.home')}
        </a>
        <span class="sep" aria-hidden="true">›</span>
        <a href={localizedPath(lang, '/posts')}>{t('breadcrumb.posts')}</a>
        <span class="sep" aria-hidden="true">›</span>
        <span class="current">{post.data.title}</span>
      </nav>

      <h1>{post.data.title}</h1>

      <div class="meta">
        <span class="meta-item">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
          {dateLabel}
        </span>
        <span class="meta-item">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/></svg>
          {wordCountLabel}
        </span>
        {post.data.updatedDate && (
          <span class="meta-item">· {t('post.updated')} {dateFormatter.format(post.data.updatedDate)}</span>
        )}
        {post.data.tags.length > 0 && (
          <div class="tag-cloud">
            {post.data.tags.map((tag) => {
              const pal = tagPalette(tag);
              return (
                <a class="tag" href={localizedPath(lang, `/tags/${tag}`)}
                   style={`--tag-bg:${pal.bg};--tag-fg:${pal.fg}`}>
                  {tag}
                </a>
              );
            })}
          </div>
        )}
      </div>

      <Content />

      {post.data.sources.length > 0 && (
        <section>
          <h2>{t('post.sources')}</h2>
          <ul class="sources-list">
            {post.data.sources.map((s) => (
              <li>
                <a href={s.url} target="_blank" rel="noopener noreferrer">
                  {s.title}
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      {related.length > 0 && (
        <section class="related-posts">
          <h2>Related posts</h2>
          <ul class="related-list">
            {related.map((p) => (
              <li>
                <a href={localizedPath(lang, `/posts/${p.data.slug}`)}>
                  <strong>{p.data.title}</strong>
                  <span class="related-desc">{p.data.description.slice(0, 100)}…</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      )}

      <p><a href={localizedPath(lang, '/posts')}>{t('post.backToList')}</a></p>
    </div>
  </article>
</BaseLayout>
