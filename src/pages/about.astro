---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/ui';

const lang = 'zh-TW' as const;
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t('about.title')}>
  <h1>{t('about.title')}</h1>
  <p>
    本站專注於 <strong>HCL Domino</strong> 與其周邊生態系（Notes、Domino REST API、Volt MX、Nomad、AppDev Pack 等）
    的最新動態與技術文章。
  </p>
  <p>
    每天由 GitHub Actions 排程觸發 OpenAI（含 Web Search），整理過去 24-72
    小時內的相關新聞與部落格文章，自動產出繁體中文與英文兩種版本，並標上對應的 tag。
  </p>
  <p>
    程式碼開源於 <a href="https://github.com/bryanHsiao/domino-news">GitHub</a>。
  </p>
</BaseLayout>
