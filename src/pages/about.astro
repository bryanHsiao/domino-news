---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/ui';

const lang = 'zh-TW' as const;
const t = useTranslations(lang);
---

<BaseLayout lang={lang} title={t('about.title')}>
  <h1>{t('about.title')}</h1>
  <p>
    本站專注於 <strong>HCL Domino</strong> 與其周邊生態系（Notes、Domino REST API、Volt MX、Nomad、AppDev Pack 等）
    的最新動態與技術文章。
  </p>
  <p>
    題材主要來自過去 24–72 小時的官方公告、HCL Ambassador 部落格、OpenNTF
    動態；當天若無新聞，則改寫官方文檔深度教學。每篇文章末尾都會列出實際參考的來源連結。
  </p>
  <p>
    繁體中文與英文版同步發布。整套發文流程的程式碼
    <a href="https://github.com/bryanHsiao/domino-news">開源於 GitHub</a>。
  </p>
</BaseLayout>
