---
import { useTranslations } from '../i18n/ui';

interface Props {
  lang: 'zh-TW' | 'en';
  currentPage: number;
  lastPage: number;
  prevUrl?: string;
  nextUrl?: string;
  /** Path between BASE_URL and the page number. Examples: "", "/posts", "/en", "/en/posts" */
  basePath: string;
}

const { lang, currentPage, lastPage, prevUrl, nextUrl, basePath } = Astro.props;
const t = useTranslations(lang);
const base = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');

function pageUrl(n: number): string {
  if (n === 1) return `${base}${basePath}/`;
  return `${base}${basePath}/${n}/`;
}

/**
 * Build a compact page-number list with first, last, current ± 1,
 * and `…` ellipses for gaps. Pattern matches what readers expect
 * from numbered pagination: e.g. for 20 pages with current=5
 * → 1 … 4 5 6 … 20
 */
function buildPageList(current: number, total: number): (number | 'ellipsis')[] {
  if (total <= 7) {
    return Array.from({ length: total }, (_, i) => i + 1);
  }
  const result: (number | 'ellipsis')[] = [];
  result.push(1);
  if (current > 4) result.push('ellipsis');
  const start = Math.max(2, current - 1);
  const end = Math.min(total - 1, current + 1);
  for (let i = start; i <= end; i++) result.push(i);
  if (current < total - 3) result.push('ellipsis');
  result.push(total);
  return result;
}

const pages = buildPageList(currentPage, lastPage);
---

{lastPage > 1 && (
  <nav class="pagination" aria-label="Pagination">
    {prevUrl ? (
      <a href={prevUrl} rel="prev" class="page-link page-arrow" aria-label={t('pagination.prev')}>
        ‹ <span class="arrow-text">{t('pagination.prev')}</span>
      </a>
    ) : (
      <span class="page-link page-arrow disabled" aria-disabled="true">
        ‹ <span class="arrow-text">{t('pagination.prev')}</span>
      </span>
    )}

    {pages.map((n) =>
      n === 'ellipsis' ? (
        <span class="page-ellipsis" aria-hidden="true">…</span>
      ) : n === currentPage ? (
        <span class="page-link page-current" aria-current="page" aria-label={`Page ${n}, current`}>{n}</span>
      ) : (
        <a href={pageUrl(n)} class="page-link" aria-label={`Page ${n}`}>{n}</a>
      )
    )}

    {nextUrl ? (
      <a href={nextUrl} rel="next" class="page-link page-arrow" aria-label={t('pagination.next')}>
        <span class="arrow-text">{t('pagination.next')}</span> ›
      </a>
    ) : (
      <span class="page-link page-arrow disabled" aria-disabled="true">
        <span class="arrow-text">{t('pagination.next')}</span> ›
      </span>
    )}
  </nav>
)}

<style>
  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-color, #e5e5e5);
    flex-wrap: wrap;
    font-size: 0.95rem;
  }
  .page-link {
    min-width: 2.6rem;
    height: 2.6rem;
    padding: 0 0.8rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--border-color, #e5e5e5);
    border-radius: 0.6rem;
    color: var(--text, #333);
    text-decoration: none;
    background: white;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
    line-height: 1;
  }
  .page-link:hover {
    background: var(--bg-hover, #f5f5f5);
    border-color: var(--text-muted, #999);
    text-decoration: none;
  }
  .page-current {
    background: var(--link, #0a66c2);
    color: white;
    border-color: var(--link, #0a66c2);
    font-weight: 600;
    cursor: default;
  }
  .page-current:hover {
    background: var(--link, #0a66c2);
    border-color: var(--link, #0a66c2);
  }
  .page-arrow {
    padding: 0 0.9rem;
    gap: 0.25rem;
  }
  .arrow-text {
    font-size: 0.9rem;
  }
  .disabled {
    color: var(--text-disabled, #ccc);
    cursor: not-allowed;
    background: white;
  }
  .disabled:hover {
    background: white;
    border-color: var(--border-color, #e5e5e5);
  }
  .page-ellipsis {
    padding: 0 0.5rem;
    color: var(--text-muted, #999);
    user-select: none;
  }

  /* Narrow screens — hide the "Prev / Next" text labels, keep arrows */
  @media (max-width: 480px) {
    .arrow-text {
      display: none;
    }
    .page-arrow {
      padding: 0 0.6rem;
      min-width: 2.6rem;
    }
    .pagination {
      gap: 0.3rem;
    }
  }
</style>
