---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { useTranslations, localizedPath, languages, defaultLang, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  /** Path under public/ (e.g. "/covers/foo.png"). Used for og:image / twitter:image. */
  cover?: string;
  /** "article" for post pages, "website" elsewhere. Defaults to "website". */
  ogType?: 'article' | 'website';
  /** Optional JSON-LD object (e.g. BlogPosting). Will be JSON.stringify'd. */
  jsonLd?: unknown;
}

const { lang, title, description, cover, ogType = 'website', jsonLd } = Astro.props;
const t = useTranslations(lang);
const siteTitle = t('site.title');
const pageTitle = title ? `${title} · ${siteTitle}` : `${siteTitle} — ${t('site.tagline')}`;
const pageDesc = description ?? t('site.description');

// Build the "switch language" target by replacing the lang segment.
const otherLang: Lang = lang === 'zh-TW' ? 'en' : 'zh-TW';
const path = Astro.url.pathname.replace(import.meta.env.BASE_URL, '/').replace(/\/+/g, '/');
const stripped = path.startsWith(`/${lang}/`)
  ? path.slice(`/${lang}`.length)
  : path === `/${lang}`
    ? '/'
    : path;
const switchHref = localizedPath(otherLang, stripped || '/');
const baseNoSlash = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');

// Absolute URLs for SEO/social tags
const siteOrigin = Astro.site ? Astro.site.origin : 'https://bryanhsiao.github.io';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? siteOrigin).toString();
const defaultOgImage = `${siteOrigin}${baseNoSlash}/covers/welcome.png`;
const ogImageUrl = cover
  ? `${siteOrigin}${baseNoSlash}${cover.startsWith('/') ? cover : `/${cover}`}`
  : defaultOgImage;
const otherLangPath = stripped || '/';
const otherLangUrl = new URL(localizedPath(otherLang, otherLangPath), Astro.site ?? siteOrigin).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* Enable SPA-like navigation: smoother transitions, no full-page flash on
        same-origin link clicks. Also lets us hook scroll restoration into
        astro:after-swap for the language switch. */}
    <ClientRouter />
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="uWwnWx3Ivqlo48BmGzuxL64y25IDjRrFLfEzimHY_Xg" />
    <link rel="icon" type="image/svg+xml" href={`${baseNoSlash}/favicon.svg`} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteTitle} (${languages[lang]})`}
      href={`${baseNoSlash}/rss-${lang}.xml`}
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={otherLang} href={otherLangUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={title ?? siteTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === 'zh-TW' ? 'zh_TW' : 'en_US'} />

    {/* Twitter / X card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ?? siteTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{pageTitle}</title>

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a href={localizedPath(lang, '/')} class="brand">
          <span class="brand-mark">D</span>
          <span>{siteTitle}</span>
        </a>
        <nav>
          <a href={localizedPath(lang, '/posts')}>{t('nav.posts')}</a>
          <a href={localizedPath(lang, '/tags')}>{t('nav.tags')}</a>
          <a href={localizedPath(lang, '/search')}>{t('nav.search')}</a>
          <a href={localizedPath(lang, '/posts/welcome')}>{t('nav.about')}</a>
          <a href={switchHref} class="lang-switch" aria-label="switch language" data-lang-switch>
            {t('lang.switch')}
          </a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div>{t('footer.poweredBy')}</div>
    </footer>

    <script is:inline>
      // Cross-language scroll restoration.
      //
      // When user clicks the language switcher, save the index of the nearest
      // H2/H3 above their viewport into sessionStorage. After the new (other-
      // language) page is loaded, scroll to the same-index heading — the zh-TW
      // and EN articles mirror each other's heading structure exactly, so the
      // user lands at the equivalent place in the translation.
      //
      // Listening to both `astro:after-swap` (view transitions path) and
      // `pageshow` (fallback for browsers without view-transition support or
      // when the polyfill bails out). The first one to fire pulls + clears
      // the saved index; the second sees an empty store and no-ops.
      (function () {
        function saveHeadingIdx(e) {
          var link =
            e.target && e.target.closest && e.target.closest('[data-lang-switch]');
          if (!link) return;
          var headings = document.querySelectorAll('article h2, article h3');
          var cutoff = window.scrollY + 100; // small offset for sticky header / cushion
          var idx = -1;
          for (var i = 0; i < headings.length; i++) {
            var top = headings[i].getBoundingClientRect().top + window.scrollY;
            if (top > cutoff) break;
            idx = i;
          }
          sessionStorage.setItem('langSwitchHeadingIdx', String(idx));
        }
        function restore() {
          var s = sessionStorage.getItem('langSwitchHeadingIdx');
          if (s === null) return;
          sessionStorage.removeItem('langSwitchHeadingIdx');
          var idx = parseInt(s, 10);
          if (idx < 0) return; // user was above any heading — leave at top
          requestAnimationFrame(function () {
            var headings = document.querySelectorAll('article h2, article h3');
            var target = headings[idx];
            if (target) target.scrollIntoView({ behavior: 'instant', block: 'start' });
          });
        }
        document.addEventListener('click', saveHeadingIdx);
        document.addEventListener('astro:after-swap', restore);
        window.addEventListener('pageshow', restore);
      })();
    </script>
  </body>
</html>
