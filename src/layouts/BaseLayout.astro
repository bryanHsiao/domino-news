---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { useTranslations, localizedPath, languages, defaultLang, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  /** Path under public/ (e.g. "/covers/foo.webp"). Used for og:image / twitter:image. */
  cover?: string;
  /** "article" for post pages, "website" elsewhere. Defaults to "website". */
  ogType?: 'article' | 'website';
  /** Optional JSON-LD object (e.g. BlogPosting). Will be JSON.stringify'd. */
  jsonLd?: unknown;
}

const { lang, title, description, cover, ogType = 'website', jsonLd } = Astro.props;
const t = useTranslations(lang);
const siteTitle = t('site.title');
const pageTitle = title ? `${title} · ${siteTitle}` : `${siteTitle} — ${t('site.tagline')}`;
const fullDesc = description ?? t('site.description');
// Google SERP shows ~155 chars of meta description; longer descriptions are
// truncated mid-sentence. Twitter cards similarly cap around 200 chars,
// LinkedIn around 150. The article frontmatter often runs 300-500 chars
// (it's a rich summary, useful for JSON-LD structured data which has no
// limit). For HTML meta tags + og: + twitter: cards we truncate to 155
// chars so SERPs / share previews display the full string.
const pageDesc =
  fullDesc.length <= 155 ? fullDesc : fullDesc.slice(0, 155).trimEnd() + '…';

// Build the "switch language" target by replacing the lang segment.
const otherLang: Lang = lang === 'zh-TW' ? 'en' : 'zh-TW';
const path = Astro.url.pathname.replace(import.meta.env.BASE_URL, '/').replace(/\/+/g, '/');
const stripped = path.startsWith(`/${lang}/`)
  ? path.slice(`/${lang}`.length)
  : path === `/${lang}`
    ? '/'
    : path;
const switchHref = localizedPath(otherLang, stripped || '/');
const baseNoSlash = (import.meta.env.BASE_URL || '/').replace(/\/+$/, '');

// Absolute URLs for SEO/social tags
const siteOrigin = Astro.site ? Astro.site.origin : 'https://bryanhsiao.github.io';
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? siteOrigin).toString();
// og:image / twitter:image use the .png fallback (not .webp) because some
// social-share preview generators — LinkedIn in particular — don't render
// WebP reliably. Page-internal use of the cover (post hero / card grid)
// stays on .webp via the original `cover` prop. PNG fallbacks are produced
// alongside every WebP by scripts/lib/cover-prompt.ts and the one-time
// scripts/generate-png-cover-fallback.ts.
const defaultOgImage = `${siteOrigin}${baseNoSlash}/covers/welcome.png`;
const coverPngPath = cover ? cover.replace(/\.webp$/, '.png') : null;
const ogImageUrl = coverPngPath
  ? `${siteOrigin}${baseNoSlash}${coverPngPath.startsWith('/') ? coverPngPath : `/${coverPngPath}`}`
  : defaultOgImage;
const otherLangPath = stripped || '/';
const otherLangUrl = new URL(localizedPath(otherLang, otherLangPath), Astro.site ?? siteOrigin).toString();
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    {/* Enable SPA-like navigation: smoother transitions, no full-page flash on
        same-origin link clicks. Also lets us hook scroll restoration into
        astro:after-swap for the language switch. */}
    <ClientRouter />
    <meta name="description" content={pageDesc} />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="uWwnWx3Ivqlo48BmGzuxL64y25IDjRrFLfEzimHY_Xg" />
    <link rel="icon" type="image/svg+xml" href={`${baseNoSlash}/favicon.svg`} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${siteTitle} (${languages[lang]})`}
      href={`${baseNoSlash}/rss-${lang}.xml`}
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang={lang} href={canonicalUrl} />
    <link rel="alternate" hreflang={otherLang} href={otherLangUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={title ?? siteTitle} />
    <meta property="og:description" content={pageDesc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content={lang === 'zh-TW' ? 'zh_TW' : 'en_US'} />

    {/* Twitter / X card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ?? siteTitle} />
    <meta name="twitter:description" content={pageDesc} />
    <meta name="twitter:image" content={ogImageUrl} />

    <title>{pageTitle}</title>

    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a href={localizedPath(lang, '/')} class="brand">
          <span class="brand-mark">D</span>
          <span>{siteTitle}</span>
        </a>
        <nav>
          <a href={localizedPath(lang, '/posts')}>{t('nav.posts')}</a>
          <a href={localizedPath(lang, '/tags')}>{t('nav.tags')}</a>
          <a href={localizedPath(lang, '/search')}>{t('nav.search')}</a>
          <a href={localizedPath(lang, '/posts/welcome')}>{t('nav.about')}</a>
          <div class="lang-toggle" role="group" aria-label="language switch">
            <span class="lang-option is-active" aria-current="true">{t('lang.current')}</span>
            <a href={switchHref} class="lang-option" aria-label="switch language" data-lang-switch>{t('lang.switch')}</a>
          </div>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div>{t('footer.poweredBy')}</div>
    </footer>

    <script is:inline>
      // Cross-language scroll restoration.
      //
      // When user clicks the language switcher, save their position so the
      // other-language page can land them at the equivalent spot. Two modes:
      //
      //  - Article pages (have <article> with H2/H3): save the INDEX of the
      //    nearest H2/H3 above viewport. The zh-TW and EN articles mirror
      //    each other's heading structure, so same-index heading is the
      //    right landmark even though the text/length differs.
      //
      //  - Everything else (post list, tag pages, search, homepage): save
      //    the raw scrollY. Card grids etc. mirror 1:1 between languages
      //    so the absolute pixel offset is close enough.
      //
      // Listening to both `astro:after-swap` (view transitions path) and
      // `pageshow` (fallback when view transitions don't run). The first
      // one to fire pulls + clears the saved state; the other no-ops.
      (function () {
        var KEY = 'langSwitchPos';

        function saveOnLangSwitch(e) {
          var link =
            e.target && e.target.closest && e.target.closest('[data-lang-switch]');
          if (!link) return;
          var headings = document.querySelectorAll('article h2, article h3');
          var payload;
          if (headings.length > 0) {
            var cutoff = window.scrollY + 100; // small cushion for sticky header
            var idx = -1;
            for (var i = 0; i < headings.length; i++) {
              var top = headings[i].getBoundingClientRect().top + window.scrollY;
              if (top > cutoff) break;
              idx = i;
            }
            payload = { kind: 'heading', idx: idx };
          } else {
            payload = { kind: 'scroll', y: window.scrollY };
          }
          try {
            sessionStorage.setItem(KEY, JSON.stringify(payload));
          } catch (err) {
            // private mode, quota, etc. — silently skip
          }
        }

        function restore() {
          var raw;
          try {
            raw = sessionStorage.getItem(KEY);
          } catch (err) {
            return;
          }
          if (!raw) return;
          try {
            sessionStorage.removeItem(KEY);
          } catch (err) {}
          var saved;
          try {
            saved = JSON.parse(raw);
          } catch (err) {
            return;
          }
          requestAnimationFrame(function () {
            if (saved.kind === 'heading') {
              if (saved.idx < 0) return; // user was above any heading; leave at top
              var headings = document.querySelectorAll('article h2, article h3');
              var target = headings[saved.idx];
              if (target) target.scrollIntoView({ behavior: 'instant', block: 'start' });
            } else if (saved.kind === 'scroll') {
              window.scrollTo({ top: saved.y, behavior: 'instant' });
            }
          });
        }

        document.addEventListener('click', saveOnLangSwitch);
        document.addEventListener('astro:after-swap', restore);
        window.addEventListener('pageshow', restore);
      })();
    </script>
  </body>
</html>
